# Copy this file to .env (repo root) and fill in the values.
# .env is gitignored.

# --- Server ---
# Local Postgres (install natively — no Docker). Create DB + role first:
#   createdb poker && createuser poker --pwprompt   (or via psql, see docs/SETUP.md)
DATABASE_URL=postgresql://poker:poker@localhost:5432/poker

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
JWT_SECRET=change-me-to-a-long-random-string
PORT=3001

# --- Client (Vite — must be prefixed with VITE_) ---
VITE_DISCORD_CLIENT_ID=
# In dev the client talks to the server through the Vite proxy, so this is
# only needed if you point the client at a remote server (e.g. Railway in prod).
VITE_SERVER_URL=
